.DS_Store
Thumbs.db

# logs
*.log

# coverage
coverage/
.nyc_output/

# local data
data/
*.db
*.sqlite

# claude code transient state (rewritten by harness on each run)
# include subdir-drift variants — handoff sometimes saves into web/.claude/ etc.
**/.claude/handoff.md
**/.claude/scheduled_tasks.lock

# nudo tool config — per-dev workspace metadata, not product code
.nudo.toml

# transient artifacts (bug repros, throwaway notes, scratch)
tmp/
.claude/
.npmrc

# Credentials kept next to the project for convenience. Untracked is
# not enough on its own: this repo is mirrored to a public one, and a
# single `git add -A` would push live keys there irreversibly.
.keys
.keys.*
*.pem
