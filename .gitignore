# rust
target/

# node
node_modules/
*.tsbuildinfo

# build outputs
dist/
build/
.astro/

# xcode
*.xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/

# android
.gradle/
local.properties

# react native / expo / metro
.expo/
.metro-cache/

