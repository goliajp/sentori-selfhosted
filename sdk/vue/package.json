{
  "name": "@goliapkg/sentori-vue",
  "version": "1.2.0",
  "description": "Vue 3 adapter for Sentori — plugin, errorHandler hook, Vue Router auto-trace navigation, <SentoriErrorBoundary>.",
  "license": "Apache-2.0 OR MIT",
  "author": "GOLIA K.K. <takagi@golia.jp> (https://golia.jp)",
  "homepage": "https://sentori.golia.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goliajp/sentori.git",
    "directory": "sdk/vue"
  },
  "bugs": {
    "url": "https://github.com/goliajp/sentori/issues"
  },
  "keywords": [
    "sentori",
    "vue",
    "vue3",
    "error-tracking",
    "error-boundary"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./router": {
      "types": "./lib/router.d.ts",
      "default": "./lib/router.js"
    }
  },
  "files": [
    "lib/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "vue": ">=3.4",
    "vue-router": ">=4"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@goliapkg/sentori-core": "^1.3.0",
    "@goliapkg/sentori-javascript": "^1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^7",
    "vue": "^3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
