{
  "name": "@goliapkg/sentori-next",
  "version": "1.1.1",
  "description": "Next.js adapter for Sentori — instrumentation.ts hooks, App Router error boundary, navigation tracing, env-driven provider built on @goliapkg/sentori-react.",
  "license": "Apache-2.0 OR MIT",
  "author": "GOLIA K.K. <takagi@golia.jp> (https://golia.jp)",
  "homepage": "https://sentori.golia.jp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goliajp/sentori.git",
    "directory": "sdk/next"
  },
  "bugs": {
    "url": "https://github.com/goliajp/sentori/issues"
  },
  "keywords": [
    "sentori",
    "error-tracking",
    "next",
    "nextjs",
    "app-router"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./client": {
      "types": "./lib/client.d.ts",
      "default": "./lib/client.js"
    },
    "./server": {
      "types": "./lib/server.d.ts",
      "default": "./lib/server.js"
    },
    "./instrumentation": {
      "types": "./lib/instrumentation.d.ts",
      "default": "./lib/instrumentation.js"
    },
    "./app-router": {
      "types": "./lib/app-router.d.ts",
      "default": "./lib/app-router.js"
    },
    "./push": {
      "types": "./lib/push.d.ts",
      "default": "./lib/push.js"
    }
  },
  "files": [
    "lib/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "dependencies": {
    "@goliapkg/sentori-core": "^1.3.1",
    "@goliapkg/sentori-javascript": "^1.3.0",
    "@goliapkg/sentori-react": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "react": "^19",
    "typescript": "^6"
  },
  "publishConfig": {
    "access": "public"
  }
}
