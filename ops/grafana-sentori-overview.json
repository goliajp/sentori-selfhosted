{
  "annotations": { "list": [] },
  "description": "Sentori — ops overview. Ingestion throughput, latency, error rate, quota drops.",
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "Ingest rate (events / sec)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (status) (rate(sentori_ingest_total[1m]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ingest latency (p50 / p99)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(sentori_ingest_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(sentori_ingest_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Quota drops (events / sec)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(sentori_quota_drops_total[1m])", "legendFormat": "drops" }]
    },
    {
      "type": "stat",
      "title": "Ingest error rate (5m)",
      "description": "rejected + quota_exceeded as a fraction of all ingest attempts",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(sentori_ingest_total{status=~\"rejected|quota_exceeded\"}[5m])) / clamp_min(sum(rate(sentori_ingest_total[5m])), 1)"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["sentori", "ops"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Sentori — Overview",
  "uid": "sentori-overview",
  "version": 1
}
