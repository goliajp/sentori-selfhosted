{
  "name": "@sentori/webapp",
  "version": "0.1.0",
  "private": true,
  "description": "Sentori v0.1 minimal dashboard shell. Imports from self-hosted/web + saas/web.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "check": "tsc -b --noEmit && eslint . && node devtools/check-i18n.mjs && node devtools/check-hardcoded-text.mjs",
    "mock": "node devtools/mock-api.mjs",
    "sweep": "node devtools/sweep.mjs",
    "check:i18n": "node devtools/check-i18n.mjs",
    "check:text": "node devtools/check-hardcoded-text.mjs"
  },
  "dependencies": {
    "@goliapkg/gds": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5"
  }
}
