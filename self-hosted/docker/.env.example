# Sentori self-hosted — copy to .env + edit before
# `docker compose up`.

# ── postgres ───────────────────────────────────────────────
POSTGRES_USER=sentori
POSTGRES_PASSWORD=CHANGE_ME_NOW
POSTGRES_DB=sentori
POSTGRES_PORT=5432

# ── server ─────────────────────────────────────────────────
SENTORI_PORT=8080
SENTORI_VERSION=0.2.0
RUST_LOG=info,sqlx=warn

# ── bootstrap (first boot only) ────────────────────────────
# Set BOTH to auto-create the first Owner user on first
# boot. Leave UNSET to disable bootstrap; you'll need to
# sign up via the dashboard.
SENTORI_BOOTSTRAP_OWNER_EMAIL=
SENTORI_BOOTSTRAP_OWNER_PASSWORD=

# ── session middleware (required for /admin/api/* in prod) ──
# 32-byte secret HMACs cookie-session payloads. Generate with:
#   openssl rand -base64 24 | head -c 32
# If unset, the server uses an ephemeral random key — sessions
# silently invalidate on every restart. Fine for dev, not prod.
SENTORI_SESSION_SECRET=

# Cookie Secure attribute. Defaults to ON (requires HTTPS).
# Flip to 0 for local-dev plain HTTP (otherwise browsers reject
# the cookie). MUST be left ON in production.
# SENTORI_COOKIE_SECURE=1

# ── attachment store ───────────────────────────────────────
# Where event_attachments + replay frames + screenshots live.
# - unset / "memory" : in-process HashMap (lost on restart)
# - "fs:/data/blobs" : on-disk; mount a docker volume here
#                       for persistence.
# SENTORI_ATTACHMENT_STORE=fs:/data/blobs

# ── saasadmin role gating ──────────────────────────────────
# Comma-separated UUIDs of users allowed to view
# /admin/api/saas/* (cross-workspace view). Leave UNSET to
# open it to any logged-in user (default — safe in single-
# workspace self-hosted; you almost certainly want to set
# this in a SaaS deployment).
# SENTORI_SAASADMIN_USER_IDS=018e34cd-0001-0001-0001-000000000001

# ── push worker ────────────────────────────────────────────
# Set to 0 / false to disable the background push dispatcher.
# Interval = how often to drain push_sends.status='queued'.
# Batch = max sends per poll.
# SENTORI_PUSH_WORKER_ENABLED=1
# SENTORI_PUSH_WORKER_INTERVAL_SEC=5
# SENTORI_PUSH_WORKER_BATCH=100
